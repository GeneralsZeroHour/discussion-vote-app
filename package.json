{
  "name": "discussion-vote-app",
  "version": "1.0.0",
  "description": "GitHub App that summarizes discussion votes in the discussion title",
  "type": "module",
  "main": "./dist/src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "create-proxy-channel": "npm run build && node dist/src/create-proxy-channel.js",
    "dev": "tsx watch src/server.ts",
    "proxy": "npm run build && node dist/src/proxy.js",
    "smoke": "npm run build && node dist/src/smoke.js",
    "simulate": "npm run build && node dist/src/simulate.js",
    "start": "npm run build && node dist/src/server.js",
    "test": "npm run build && node dist/test/vote-summary.test.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GeneralsZeroHour/discussion-vote-app.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/GeneralsZeroHour/discussion-vote-app/issues"
  },
  "homepage": "https://github.com/GeneralsZeroHour/discussion-vote-app#readme",
  "dependencies": {
    "probot": "13.4.7",
    "smee-client": "2.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
